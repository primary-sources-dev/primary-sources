{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "organizations.schema.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["org_id", "name"],
    "properties": {
      "org_id": { "$ref": "../common/common.schema.json#/$defs/idString" },
      "name": { "type": "string", "minLength": 1 },
      "display_name": { "$ref": "../common/common.schema.json#/$defs/stringOrNull" },
      "org_type": { "$ref": "../common/common.schema.json#/$defs/stringOrNull" },
      "description": { "$ref": "../common/common.schema.json#/$defs/stringOrNull" },
      "notes": { "$ref": "../common/common.schema.json#/$defs/stringOrNull" },
      "members": { "$ref": "../common/common.schema.json#/$defs/objectArray" },
      "events": { "$ref": "../common/common.schema.json#/$defs/objectArray" },
      "locations": { "$ref": "../common/common.schema.json#/$defs/objectArray" },
      "sources": { "$ref": "../common/common.schema.json#/$defs/objectArray" },
      "tags": { "$ref": "../common/common.schema.json#/$defs/stringArray" }
    }
  }
}

